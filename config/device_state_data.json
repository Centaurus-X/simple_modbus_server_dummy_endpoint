  "control_method_templates": [
    {
      "template_id": 1,
      "template_name": "ramp",
      "template_description": "Linear ramp v0 to v1 over t_ramp",
      "type": "ramp",
      "parameters": [
        "v0",
        "v1",
        "t_ramp"
      ]
    },
    {
      "template_id": 2,
      "template_name": "square",
      "template_description": "Square wave: low/high, period, duty cycle, optional duration",
      "type": "square",
      "parameters": [
        "low",
        "high",
        "period_s",
        "duty",
        "duration_s"
      ]
    },
    {
      "template_id": 3,
      "template_name": "sine",
      "template_description": "Sine: amplitude, offset, period, phase, optional duration",
      "type": "sine",
      "parameters": [
        "amp",
        "offset",
        "period_s",
        "phase_deg",
        "duration_s"
      ]
    },
    {
      "template_id": 4,
      "template_name": "poly2",
      "template_description": "Quadratic: A*(t - t0)^2 + B over a duration",
      "type": "expr",
      "expr_id": "poly2",
      "parameters": [
        "A",
        "B",
        "t0",
        "duration_s"
      ]
    },
    {
      "template_id": 5,
      "template_name": "impulse",
      "template_description": "Dirac-like impulse as a short rectangular pulse",
      "type": "impulse",
      "parameters": [
        "amp",
        "duration_s"
      ]
    },
    {
      "template_id": 6,
      "template_name": "inv_sin",
      "template_description": "(A/(t - t0 + eps)) * sin(2π/period_s * (t - t0)) + offset",
      "type": "expr",
      "expr_id": "inv_sin",
      "parameters": [
        "A",
        "period_s",
        "t0",
        "duration_s",
        "eps",
        "offset"
      ]
    },
    {
      "template_id": 7,
      "template_name": "log_n",
      "template_description": "A * log(k*(t - t0) + 1) + B over a duration",
      "type": "expr",
      "expr_id": "log_n",
      "parameters": [
        "A",
        "k",
        "B",
        "t0",
        "duration_s"
      ]
    },
    {
      "template_id": 8,
      "template_name": "exp",
      "template_description": "A * exp(sign*k*(t - t0)) + B over a duration (sign in {+1,-1})",
      "type": "expr",
      "expr_id": "exp",
      "parameters": [
        "A",
        "k",
        "sign",
        "B",
        "t0",
        "duration_s"
      ]
    }
  ],
